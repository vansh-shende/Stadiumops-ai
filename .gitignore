# ─── StadiumOps AI — Root .gitignore ───

# Dependencies
**/node_modules/

# Environment Variables
**/.env
**/.env*.local

# Database Files
**/*.db
**/*.db-*
**/*.sqlite
**/*.sqlite3

# Build Output
**/dist/
**/dist-ssr/

# Vercel
**/.vercel/

# Logs
*.log
npm-debug.log*
yarn-debug.log*

# Editor & System Files
.vscode/
.idea/
.DS_Store
Thumbs.db
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
